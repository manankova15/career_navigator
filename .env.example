# Shared
ENVIRONMENT=development
PROJECT_NAME=Career Navigator
PROJECT_SLUG=career_nagigator
LOG_LEVEL=INFO
PYTHONPATH=.

# Infrastructure
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=career_navigator
POSTGRES_USER=career_navigator
POSTGRES_PASSWORD=change_me

REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=career_analytics

S3_ENDPOINT=http://minio:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_MODELS=career-models

# Auth
JWT_SECRET=change_me_to_a_long_random_secret
INTERNAL_TOKEN=change_me_internal_token
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

# Notification channels
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=change_me
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_WEBHOOK_SECRET=change_me

# Service ports
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
PROFILE_SERVICE_PORT=8002
SOURCE_SERVICE_PORT=8003
VACANCY_SERVICE_PORT=8004
RECOMMENDATION_SERVICE_PORT=8005
ML_SERVICE_PORT=8006
ASSESSMENT_SERVICE_PORT=8007
ANALYTICS_SERVICE_PORT=8008
NOTIFICATION_SERVICE_PORT=8009
ADMIN_SERVICE_PORT=8010
BOT_SERVICE_PORT=8011
INGESTION_WORKER_PORT=8012

# HH.ru API (получается на https://dev.hh.ru/admin)
# Без OAuth-токена публичный API HH с 2025 отдаёт 403 forbidden
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_AUTH_TOKEN=
HH_USER_AGENT=career-navigator-thesis/1.0 (your-email@example.com)
